# Build trees
build/
build-*/
/compile_commands.json

# Generated WASM artifacts (produced by web/build-wasm.sh)
/web/vendor/
# Emscripten's writable cache (created by the flake's wasm devShell shellHook)
/.em-cache/

# Python
.venv/
.venv-torch/
.venv-bgremove/
.venv-rembg/
__pycache__/
*.pyc

# Local working caches: downloaded checkpoints, converted gguf, fetched upstream
# reference code (third-party, fetched on demand — never vendored here).
.cache/

# Model + data artifacts (generated; never committed)
*.gguf
*.safetensors
*.ckpt
*.npy

# Reference/golden fixtures are generated by scripts/hf_dump.py
/tests/fixtures/hf/

# Fuzzing
corpus_*/
crash-*
leak-*
timeout-*

# Editor / OS
.direnv/
.DS_Store

# Stray emscripten compiler-probe outputs
/a.out.js
/a.out.wasm

# Generated demo splats
/web/*.splat

# Go web-app server: locally-built binary (source + go.mod/go.sum are tracked)
/server/fsserver
/server/server
